# ============================================
# Library Management System - Environment Variables
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=library_db

# JWT Authentication
JWT_SECRET=secret_jwt_key
JWT_EXPIRES_IN=7d

# Pagination
ITEMS_PER_PAGE=10

# Borrowing defaults
DEFAULT_BORROW_DAYS=14

# Super-admin registration (keep this secret — sent as "admin-pass" header)
SUPERADMINPASS=change_this_super_secret_password
